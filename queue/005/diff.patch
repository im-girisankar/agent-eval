+"""Command-line interface for agent-eval.
+
+Usage
+-----
+    ageval run <bundle.json>
+
+Commands
+--------
+run <path>
+    Load a JSON bundle file, evaluate all matched runs, and print a Markdown
+    report to stdout.  Exits with code 0 on success, 1 on error.
+"""
+
+from __future__ import annotations
+
+import sys
+from pathlib import Path
+
+
+def _cmd_run(args: list[str]) -> int:
+    """Implement the ``ageval run <path>`` sub-command.
+
+    Args:
+        args: Remaining CLI arguments after the ``run`` keyword.
+
+    Returns:
+        Exit code (0 = success, 1 = error).
+    """
+    if not args:
+        print("Usage: ageval run <bundle.json>", file=sys.stderr)
+        return 1
+
+    path = Path(args[0])
+    if not path.exists():
+        print(f"Error: file not found: {path}", file=sys.stderr)
+        return 1
+
+    # Import here so CLI startup is fast even if running --help
+    from agent_eval.harness import load_bundle
+
+    try:
+        bundle = load_bundle(path)
+    except Exception as exc:  # noqa: BLE001
+        print(f"Error loading bundle: {exc}", file=sys.stderr)
+        return 1
+
+    report = bundle.evaluate()
+    print(report.render())
+    return 0
+
+
+def main(argv: list[str] | None = None) -> None:
+    """Entry point for the ``ageval`` CLI.
+
+    Args:
+        argv: Argument list (defaults to ``sys.argv[1:]``).
+    """
+    if argv is None:
+        argv = sys.argv[1:]
+
+    if not argv:
+        print("Usage: ageval <command> [args]")
+        print("Commands: run")
+        sys.exit(0)
+
+    command, *rest = argv
+
+    if command == "run":
+        code = _cmd_run(rest)
+        sys.exit(code)
+    else:
+        print(f"Unknown command: {command!r}", file=sys.stderr)
+        print("Available commands: run", file=sys.stderr)
+        sys.exit(1)
